# Порт, на котором запускается сервер
PORT=8000

# Адрес фронтенда (для CORS)
FRONTEND_URL=http://localhost:3000

# Секрет для хеширования паролей (замените на длинный случайный ключ)
SECRET_KEY=change-me-to-random-string

# Путь к файлу базы данных SQLite
DB_PATH=slotify.db

# Администратор (создаётся при старте)
ADMIN_EMAIL=admin@slotify.ru
ADMIN_PASSWORD=your-strong-password-here
ADMIN_NAME=Админ
ADMIN_PHONE=+70000000000

# API-ключ SMS.ru (получить на https://sms.ru)
SMS_RU_API_KEY=your-sms-ru-api-key-here

# Sentry DSN (бэкенд) — получить на https://sentry.io
SENTRY_DSN=
