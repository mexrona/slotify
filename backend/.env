# Порт, на котором запускается сервер
PORT=8000

# Адрес фронтенда (для CORS)
FRONTEND_URL=http://localhost:3000

# Секрет для генерации токенов (в продакшене заменить на длинный случайный ключ)
SECRET_KEY=slotify-dev-secret-key-change-me

# Телефон и имя администратора (создаётся при старте)
ADMIN_PHONE=+70000000000
ADMIN_NAME=Админ
